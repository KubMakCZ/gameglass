# ==========================================
# 🛑 GAMEGLASS - UKÁZKOVÝ SOUBOR PROMĚNNÝCH
# ==========================================
# 1. Přejmenuj tento soubor na `.env`
# 2. Vyplň údaje podle tvé instalace Appwrite
# 3. Tento soubor je ignorován gitem, takže tvá hesla neuniknou ven!

# --- PRO REACT (FRONTEND) ---
# Zde udej IP adresu nebo doménu tvého serveru (kde běží Appwrite)
VITE_APPWRITE_ENDPOINT=http://localhost/v1

# Zde vlož ID projektu z Appwrite konzole
VITE_APPWRITE_PROJECT_ID=tvoje_project_id_z_konzole

# --- PRO NODEJS AUTOMATIZACI (BACKEND SKRIPTY) ---
# Tuto proměnnou potřebuje jen Node.js skript pro prvotní nahrání 
# příkladů (seed.js), frontend s ní nepřijde do styku.
APPWRITE_API_KEY=tvuj_tajny_api_klic_pro_server
